# Per-service base URLs. Three independent FastAPI services:
# - Core    (identity, cart, likes, journal)         default 8001
# - Catalog (partners, shops, items, scenes)         default 8002
# - Generation (rooms, jobs, provider calls)         default 8003
#
# Leave blank to use the localhost defaults baked into lib/api/env.ts.

NEXT_PUBLIC_CORE_BASE=http://localhost:8001
NEXT_PUBLIC_CATALOG_BASE=http://localhost:8002
NEXT_PUBLIC_GENERATION_BASE=http://localhost:8003
